# =============================================================================
# myGameList - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the actual values.
#   cp .env.example .env
#
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Vercel Postgres / Neon)
# -----------------------------------------------------------------------------
# Pooled connection string (used by Prisma Client at runtime via PgBouncer)
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&connect_timeout=15"

# Direct (non-pooled) connection string (used for Prisma migrations)
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# The canonical URL of your site (http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# A random secret used to sign/encrypt JWTs. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"

# -----------------------------------------------------------------------------
# Google OAuth (Optional – leave empty to disable Google sign-in)
# Create credentials at https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Twitch OAuth & IGDB API
# Register an app at https://dev.twitch.tv/console/apps
# The SAME app credentials are used for both Twitch OAuth login and IGDB API.
#   TWITCH_ID / TWITCH_SECRET       → used by NextAuth (Twitch provider)
#   TWITCH_CLIENT_ID / TWITCH_CLIENT_SECRET → used by lib/igdb.ts (IGDB API)
# -----------------------------------------------------------------------------
TWITCH_ID="your-twitch-client-id"
TWITCH_SECRET="your-twitch-client-secret"
TWITCH_CLIENT_ID="your-twitch-client-id"
TWITCH_CLIENT_SECRET="your-twitch-client-secret"

# -----------------------------------------------------------------------------
# Application Domain
# Used for internal server-to-server API calls (e.g. auto-register on OAuth)
# -----------------------------------------------------------------------------
DOMAIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# UploadThing (Profile picture uploads)
# Get keys from https://uploadthing.com/dashboard
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# -----------------------------------------------------------------------------
# Google Analytics 4 (GA4 Data API – Optional)
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant "Viewer" role on your GA4 property, then create a JSON key.
# GA4_PROPERTY_ID is the numeric ID from Admin → Property Settings.
# -----------------------------------------------------------------------------
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""

# -----------------------------------------------------------------------------
# Wit.ai (AI Chatbot – Optional)
# Create an app at https://wit.ai and copy the Server Access Token
# -----------------------------------------------------------------------------
WIT_AI_TOKEN=""
